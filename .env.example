# ========================================
# ENTORNO
# ========================================
NODE_ENV=development
PORT=3000

# ========================================
# BASE DE DATOS - SQLite (LOCAL/VERCEL)
# ========================================
DATABASE_URL=file:./var/data.db
DIRECT_URL=file:./var/data.db

# ========================================
# BASE DE DATOS - PostgreSQL SUPABASE (OPCIONAL)
# Descomenta las líneas si deseas usar Supabase en lugar de SQLite
# ========================================
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[PROJECT].supabase.co:5432/postgres?schema=public&sslmode=require
# DIRECT_URL=postgresql://postgres:[PASSWORD]@[PROJECT].supabase.co:5432/postgres?schema=public&sslmode=require

# ========================================
# SUPABASE (OPCIONAL - para almacenamiento de archivos)
# ========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
SUPABASE_STORAGE_BUCKET=medical-documents

# ========================================
# SESIONES Y SEGURIDAD
# ========================================
SESSION_SECRET=your_super_secret_session_key_here_change_in_production
JWT_SECRET=your_jwt_secret_key_here_change_in_production
BCRYPT_ROUNDS=10

# ========================================
# CONFIGURACIÓN DE APLICACIÓN
# ========================================
APP_NAME=Lemes
APP_DESCRIPTION=Sistema de Gestión Médica Profesional
APP_VERSION=1.0.0

# ========================================
# LOGS
# ========================================
LOG_LEVEL=debug

# ========================================
# CONFIGURACIÓN DE ARCHIVOS
# ========================================
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,xls,xlsx
# ========================================
# EMAIL (OPCIONAL - Para futuras notificaciones)
# ========================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_email_password
