<aside class="sidebar" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="sidebar-header">
        <h2 class="mb-0">
            <i class="fas fa-hospital me-2"></i>
            <span class="d-none d-lg-inline">Lemes</span>
        </h2>
    </div>

    <nav class="sidebar-nav">
        <!-- Menú General -->
        <div class="nav-section">
            <a href="/" class="nav-item">
                <i class="fas fa-home"></i>
                <span>Dashboard</span>
            </a>
        </div>

        <!-- Menú Secretaria -->
        <% if (usuario.rol === 'ROLE_SECRETARIA') { %>
            <div class="nav-section">
                <h6 class="nav-title">Pacientes</h6>
                <a href="/pacientes/nuevo" class="nav-item">
                    <i class="fas fa-user-plus"></i>
                    <span>Registrar Paciente</span>
                </a>
                <a href="/pacientes" class="nav-item">
                    <i class="fas fa-users"></i>
                    <span>Lista de Pacientes</span>
                </a>
            </div>

            <div class="nav-section">
                <h6 class="nav-title">Turnos y Citas</h6>
                <a href="/turnos/nuevo" class="nav-item">
                    <i class="fas fa-plus-square"></i>
                    <span>Crear Turno</span>
                </a>
                <a href="/turnos" class="nav-item">
                    <i class="fas fa-calendar-alt"></i>
                    <span>Gestionar Turnos</span>
                </a>
            </div>

            <div class="nav-section">
                <h6 class="nav-title">Agenda</h6>
                <a href="/agenda" class="nav-item">
                    <i class="fas fa-calendar-check"></i>
                    <span>Calendario</span>
                </a>
            </div>
        <% } %>

        <!-- Menú Doctor -->
        <% if (usuario.rol === 'ROLE_DOCTOR') { %>
            <div class="nav-section">
                <h6 class="nav-title">Consultas</h6>
                <a href="/siguiente-paciente" class="nav-item">
                    <i class="fas fa-forward"></i>
                    <span>Siguiente Paciente</span>
                </a>
                <a href="/agenda" class="nav-item">
                    <i class="fas fa-calendar-alt"></i>
                    <span>Mi Agenda</span>
                </a>
            </div>

            <div class="nav-section">
                <h6 class="nav-title">Pacientes</h6>
                <a href="/pacientes" class="nav-item">
                    <i class="fas fa-users"></i>
                    <span>Mis Pacientes</span>
                </a>
            </div>
        <% } %>

        <!-- Menú Admin -->
        <% if (usuario.rol === 'ROLE_ADMIN') { %>
            <div class="nav-section">
                <h6 class="nav-title">Administración</h6>
                <a href="/usuarios" class="nav-item">
                    <i class="fas fa-user-cog"></i>
                    <span>Gestionar Usuarios</span>
                </a>
                <a href="/reportes" class="nav-item">
                    <i class="fas fa-chart-bar"></i>
                    <span>Reportes</span>
                </a>
            </div>

            <div class="nav-section">
                <h6 class="nav-title">Sistema</h6>
                <a href="/configuracion" class="nav-item">
                    <i class="fas fa-cog"></i>
                    <span>Configuración</span>
                </a>
            </div>
        <% } %>
    </nav>

    <div class="sidebar-footer">
        <button class="btn btn-logout" id="logoutBtn">
            <i class="fas fa-sign-out-alt"></i>
            <span>Cerrar Sesión</span>
        </button>
    </div>
</aside>

<style>
    .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        width: 260px;
        height: 100vh;
        color: white;
        overflow-y: auto;
        z-index: 1030;
        box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
    }

    .sidebar-header {
        padding: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        font-size: 1.5rem;
        font-weight: 700;
    }

    .sidebar-nav {
        padding: 20px 0;
        flex: 1;
    }

    .nav-section {
        padding: 15px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .nav-title {
        padding: 0 20px;
        font-size: 0.85rem;
        text-transform: uppercase;
        opacity: 0.7;
        margin: 0 0 10px 0;
        font-weight: 600;
    }

    .nav-item {
        display: flex;
        align-items: center;
        padding: 12px 20px;
        color: rgba(255, 255, 255, 0.9);
        text-decoration: none;
        transition: all 0.3s ease;
        border-left: 3px solid transparent;
    }

    .nav-item:hover {
        background: rgba(255, 255, 255, 0.1);
        color: white;
        border-left-color: white;
        padding-left: 17px;
    }

    .nav-item i {
        width: 24px;
        margin-right: 12px;
        text-align: center;
    }

    .sidebar-footer {
        padding: 20px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .btn-logout {
        width: 100%;
        background: rgba(255, 255, 255, 0.2);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.3);
        padding: 10px 15px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: all 0.3s ease;
    }

    .btn-logout:hover {
        background: rgba(255, 255, 255, 0.3);
        color: white;
    }

    @media (max-width: 768px) {
        .sidebar {
            width: 70px;
        }

        .sidebar-header h2 span {
            display: none;
        }

        .nav-item span,
        .nav-title,
        .btn-logout span {
            display: none;
        }

        .nav-item {
            justify-content: center;
        }
    }
</style>

<script>
    document.getElementById('logoutBtn').addEventListener('click', async function() {
        try {
            await fetch('/api/auth/logout', { method: 'POST' });
            window.location.href = '/login';
        } catch (error) {
            console.error('Error:', error);
            alert('Error al cerrar sesión');
        }
    });
</script>
